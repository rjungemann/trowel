#!/usr/bin/env python3
"""Quick shell for the Trowel control socket.

Usage:
    trowel-ctl <socket_path> <cmd> [json-args]
    trowel-ctl <socket_path>                    # interactive, one cmd per line
"""

import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1] / "tests" / "support"))
from trowel_ctl import TrowelCtl, ControlError  # noqa: E402


def main() -> int:
    if len(sys.argv) < 2:
        print(__doc__.strip(), file=sys.stderr)
        return 2
    path = sys.argv[1]
    with TrowelCtl(path) as ctl:
        if len(sys.argv) >= 3:
            cmd = sys.argv[2]
            args = json.loads(sys.argv[3]) if len(sys.argv) > 3 else {}
            try:
                print(json.dumps(ctl.call(cmd, args), indent=2))
            except ControlError as e:
                print(f"error: {e}", file=sys.stderr)
                return 1
            return 0
        for line in sys.stdin:
            line = line.strip()
            if not line:
                continue
            parts = line.split(maxsplit=1)
            cmd = parts[0]
            args = json.loads(parts[1]) if len(parts) > 1 else {}
            try:
                print(json.dumps(ctl.call(cmd, args)))
            except ControlError as e:
                print(f"error: {e}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
